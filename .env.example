# TraceNet Blockchain - Environment Variables

# Server Configuration
NODE_ENV=development
PORT=3000

# JWT Authentication
# IMPORTANT: Generate a strong secret for production!
# Use: openssl rand -base64 64
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# CORS Configuration
CORS_ORIGIN=http://localhost:3000

# Blockchain Configuration
GENESIS_REWARD=1000000
BLOCK_TIME=10000
MAX_TRANSACTIONS_PER_BLOCK=100

# Database (if using external DB)
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=tracenet
# DB_USER=tracenet_user
# DB_PASSWORD=secure_password

# Logging
LOG_LEVEL=info

# Rate Limiting (requests per 15 minutes)
RATE_LIMIT_MAX=100

# Security
# HTTPS_ENABLED=true
# SSL_CERT_PATH=/path/to/cert.pem
# SSL_KEY_PATH=/path/to/key.pem

# Monitoring (optional)
# SENTRY_DSN=your-sentry-dsn
# LOG_ROCKET_APP_ID=your-logrocket-id

# Email (for notifications, optional)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASSWORD=your-app-password

# Cloud Storage (for backups, optional)
# GCS_BUCKET=tracenet-backups
# GCS_PROJECT_ID=your-project-id
