# Node Configuration
NODE_ENV=development
PORT=3000
NODE_ID=node-1

# Database Configuration
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=tracenet_blockchain
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_password_here

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# LevelDB Configuration
LEVELDB_PATH=./data/blockchain

# Blockchain Configuration
GENESIS_VALIDATOR_ID=system
BLOCK_TIME_MS=5000
MAX_TRANSACTIONS_PER_BLOCK=1000

# Consensus Configuration (DPoA)
VALIDATOR_THRESHOLD_PERCENT=66
VALIDATORS_PER_TRANSACTION=7
SIGNATURE_TIMEOUT_MS=5000

# Token Configuration
TOKEN_NAME=TraceNet
TOKEN_SYMBOL=TRN
TOKEN_DECIMALS=8
INITIAL_AIRDROP_AMOUNT=10000000000

# Security Configuration
JWT_SECRET=your_jwt_secret_here_change_in_production
JWT_EXPIRY=24h
ENCRYPTION_KEY=your_32_byte_encryption_key_here_change_in_production

# API Configuration
API_RATE_LIMIT_WINDOW_MS=60000
API_RATE_LIMIT_MAX_REQUESTS=100

# Auth Service Integration
AUTH_SERVICE_URL=http://localhost:4000
AUTH_SERVICE_API_KEY=your_auth_service_api_key

# Observability
ENABLE_TRACING=true
ENABLE_METRICS=true
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
LOG_LEVEL=info

# Cloud Configuration (for production)
GCP_PROJECT_ID=
GCP_REGION=us-central1
CLOUD_SQL_CONNECTION_NAME=
